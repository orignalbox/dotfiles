#!/bin/sh

# Colors and font
DMENU_FONT="JetBrainsMono Nerd Font Mono:size=10"
DMENU_NB="#000000"
DMENU_NF="#bbbbbb"
DMENU_SB="#222222"
DMENU_SF="#eeeeee"

# Custom shortcuts (one per line, no \n tricks)
aliases="browser
files
github
whatsapp
linkedin
vtop
youtube"

# Combine with system executables, sort, deduplicate
all_options=$(printf "%s\n%s\n" "$aliases" "$(dmenu_path)" | sort -u)

# Show dmenu
choice=$(printf "%s" "$all_options" | dmenu -p "Run:" \
    -fn "$DMENU_FONT" \
    -nb "$DMENU_NB" -nf "$DMENU_NF" \
    -sb "$DMENU_SB" -sf "$DMENU_SF")

[ -z "$choice" ] && exit

# Handle shortcuts, fall through to exec for everything else
case "$choice" in
    browser)   exec firefox ;;
    files)     exec thunar ;;
    github)    exec firefox "https://github.com" ;;
    whatsapp)  exec firefox "https://web.whatsapp.com" ;;
    linkedin)  exec firefox "https://linkedin.com" ;;
    vtop)      exec firefox "https://vtop.vitbhopal.ac.in/vtop/open/page" ;;
    youtube)   exec firefox "https://www.youtube.com" ;;
    *)         exec $choice ;;
esac
